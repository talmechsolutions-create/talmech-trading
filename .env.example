NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="https://talmechtrading.in"

# Admin security. Use strong production-only values in Vercel.
ADMIN_USERNAME=""
ADMIN_PASSWORD=""
ADMIN_SESSION_SECRET=""
ADMIN_MFA_ENABLED=false
ADMIN_MFA_EMAIL=
CLIENT_SESSION_SECRET=""
CSRF_SECRET=

# Optional rate-limit backend. Without Upstash, local in-memory limiting is used.
RATE_LIMIT_PROVIDER=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

NEXT_PUBLIC_TALMECH_WHATSAPP_NUMBER=917389642874
WHATSAPP_PROVIDER=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

RESEND_API_KEY=""

# Business/client email. Use a Zoho app-specific password for SMTP_PASSWORD.
# Do not commit real credentials. Configure these in Vercel environment variables.
EMAIL_PROVIDER=zoho_smtp
SMTP_HOST=smtppro.zoho.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
NOTIFICATION_FROM_EMAIL=
ADMIN_NOTIFICATION_EMAIL=""

METALS_DEV_API_KEY=""
METALPRICE_API_KEY=""

RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

OTP_PROVIDER_ENDPOINT=""
OTP_PROVIDER_API_KEY=""
OTP_HASH_SECRET=""
# OTP sender is separate from business/client notifications.
# If OTP_FROM_EMAIL is blank, the existing OTP provider behavior is preserved.
OTP_FROM_EMAIL=

# Do not commit real database secrets.
# DATABASE_POSTGRES_URL is used by Prisma schema for Vercel Prisma Postgres.
# DATABASE_URL is supported as fallback for other Postgres providers.
DATABASE_URL=
DATABASE_POSTGRES_URL=
DATABASE_PRISMA_DATABASE_URL=

IMAGE_UPLOAD_PROVIDER=
NEXT_PUBLIC_IMAGE_UPLOAD_MAX_MB=3
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
VERCEL_BLOB_READ_WRITE_TOKEN=

LISTING_AI_PROVIDER=
LISTING_AI_API_KEY=
LISTING_AI_MODEL=
